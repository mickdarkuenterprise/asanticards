# ── Supabase ──────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key        # Never expose this client-side

# ── Paystack ──────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx   # Server-side secret key
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx   # Safe to use client-side
PAYSTACK_WEBHOOK_SECRET=your-webhook-secret        # Set in Paystack dashboard → Webhooks

# ── Admin Auth ────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production
ADMIN_EMAIL=admin@asanticards.com
ADMIN_PASSWORD_HASH=                               # Generated on first run (see README)

# ── Email (Nodemailer) ────────────────────────────
SMTP_HOST=mail.asanticards.com                     # Namecheap cPanel SMTP host
SMTP_PORT=465
SMTP_USER=orders@asanticards.com
SMTP_PASS=your-email-password
EMAIL_FROM="ASA NTI Orders <orders@asanticards.com>"

# ── Server ────────────────────────────────────────
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://asanticards.com               # Your Namecheap domain (for CORS)
